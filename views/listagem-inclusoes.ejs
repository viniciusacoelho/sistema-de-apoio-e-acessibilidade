<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Listagem Inclusões</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/servicos.css">
</head>
<body>
    <header class="header-index">
        <%- include('partials/navbar') %>
    </header>

    <main>
        <section class="titulo-e-texto-inclusoes">
            <h1>Inclusões</h1>
            <p>Lista de lugares acessíveis.</p>
        </section>

        <!-- 🔥 MESMA ESTRUTURA DAS NOTIFICAÇÕES -->
        <section class="container-textos-e-botoes">
            
            <div class="search-box">
                <button class="btn-voltar" onclick="voltarPagina()">← Voltar</button>

                <input type="text" placeholder="Buscar locais..." class="search" id="searchInput" title="Clique na tecla / para pesquisar">

                <button onclick="buscar()" class="btn-buscar">Buscar</button>
            </div>

            <p class="contador">
                <strong>Total</strong>: 
                <span class="span-contador-notificacoes">
                    <%= inclusoes.length %>
                </span> inclusões registradas
            </p>
        </section>

        <!-- CARDS -->
        <div class="container-inclusoes">
            <% inclusoes.forEach((inclusao) => { %>
                <a href="/listagem-inclusoes/<%= inclusao._id %>" class="card-link">
                    <div class="card-inclusao">
                        <img src="<%= inclusao.imagem %>" alt="Imagem do local">

                        <div class="card-conteudo">
                            <h3><%= inclusao.nome %></h3>
                            <span class="data"><%= inclusao.data %></span>
                            <p><%= inclusao.mensagem %></p>
                        </div>
                    </div>
                </a>
            <% }) %>
        </div>
    </main>

    <!-- ATICAR CAMPO DE TEXTO COM A tecla / (slash) -->
    <script>
        document.addEventListener('keydown', function(event) {
            const searchInput = document.getElementById('searchInput');

            if (event.key === '/' || event.code === 'Slash') {
                event.preventDefault(); 
                searchInput.focus();
            }
        });
    </script>

    <!-- 🔙 VOLTAR -->
    <script>
        function voltarPagina() {
            window.history.back();
        }
    </script>

    <!-- 🔍 BUSCA EM TEMPO REAL -->
    <script>
        const search = document.getElementById('searchInput');
        const cards = document.querySelectorAll('.card-inclusao');

        search.addEventListener('input', () => {
            const value = search.value.toLowerCase();

            cards.forEach(card => {
                const text = card.innerText.toLowerCase();
                card.parentElement.style.display = text.includes(value) ? 'block' : 'none';
            });
        });
    </script>

    <!-- 🔍 BUSCA COM BOTÃO -->
    <script>
        function buscar() {
            const input = document.getElementById('searchInput').value.toLowerCase();
            const cards = document.querySelectorAll('.card-inclusao');

            cards.forEach(card => {
                const texto = card.innerText.toLowerCase();

                if (texto.includes(input)) {
                    card.parentElement.style.display = "block";
                } else {
                    card.parentElement.style.display = "none";
                }
            });
        }
    </script>

    <%- include('partials/footer') %>
</body>
</html>