<!DOCTYPE html>

<html lang="pt-br">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Sistema de Apoio e Acessibilidade</title>
        <link rel="shortcut icon" href="/images/SAA_logo_editada.png" type="image/x-icon">
        <link rel="stylesheet" href="   /css/style.css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    </head>

    <body class="body-login">
        <header>

        </header>

        <main class="">
            <section class="container-1">
                <form action="/login" method="post">
                    <% if (error) { %>
                        <div class="alert error">
                            <p><%= error %></p>
                        </div>
                    <% } %>
                    <div class="item-1">
                        <h2>Login</h2>
                        <br>
                        <p>Faça login da sua conta</p>
                    </div>

                    <div class="item-2">
                        <label for="email" class="left">E-mail<span class="right">*</span></label>
                        <div class="input-icon">
                            <i class="fa-solid fa-envelope"></i>
                            <input type="email" name="email" id="email" class="input-item-2" placeholder="Ex: @gmail, @outlook, @yahoo, etc." minlength="16" maxlength="74" required>
                        </div>
                        <br>
                        <label for="password" class="left">Senha<span class="right">*</span></label>
                        <div class="input-icon">
                            <i class="fa-solid fa-lock icon-left"></i>
                            <input type="password" name="password" id="password" class="input-item-2" placeholder="Informe sua senha" minlength="8" maxlength="25" required>
                            <i class="fa-solid fa-eye icon-right"></i>
                        </div>
                        <small class="right">*campo obrigatório</small>
                    </div>

                    <div class="item-3">
                        <label><small><a href="">Esqueceu a senha?</a></small></label>
                        <br>
                    </div>
                    <div class="button">
                        <button type="submit" class="button-size"><h2>Acessar</h2></button>
                    </div>
                    <div class="center">
                        <p>Não possue uma conta? <a href="/cadastre-se">Cadastre-se</a></p>
                    </div>
                </form>
            </section>
        </main>

        <footer>
        
        </footer>
    </body>
</html>